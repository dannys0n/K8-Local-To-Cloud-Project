# Copy to: config/cluster.env
#
# K3S_API_ENDPOINT should be a stable DNS name that resolves to your k3s server.
# - Best: DHCP reservation or static IP + DNS A record (your router / Pi-hole / DNSMasq)
# - Avoid: using a raw DHCP-assigned IP without a reservation
K3S_API_ENDPOINT=k3s-api.lan

# Optional: how long bootstrap tokens should live (used by scripts/orchestrate/join-agent-ssh.sh)
K3S_BOOTSTRAP_TTL=30m

# Optional: default SSH user for Raspberry Pi OS
WORKER_SSH_USER=pi
